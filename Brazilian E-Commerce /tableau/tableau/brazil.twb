    <worksheet name='map'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Revenue Distribution Across Brazilian States</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='by_state' name='federated.0q8q38e0wy0k3n1cxrs521fhjw86' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.0q8q38e0wy0k3n1cxrs521fhjw86'>
            <column caption='State Full name ' datatype='string' name='[Calculation_2108645980610565]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
              <calculation class='tableau' formula='CASE [customer_state]&#10;WHEN &quot;SP&quot; THEN &quot;São Paulo&quot;&#10;WHEN &quot;RJ&quot; THEN &quot;Rio de Janeiro&quot;&#10;WHEN &quot;MG&quot; THEN &quot;Minas Gerais&quot;&#10;WHEN &quot;RS&quot; THEN &quot;Rio Grande do Sul&quot;&#10;WHEN &quot;PR&quot; THEN &quot;Paraná&quot;&#10;WHEN &quot;SC&quot; THEN &quot;Santa Catarina&quot;&#10;END' />
            </column>
            <column caption='Customer State' datatype='string' name='[customer_state]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Calculation_2108645980610565]' derivation='None' name='[none:Calculation_2108645980610565:nk]' pivot='key' type='nominal' />
            <column caption='Revenue' datatype='real' name='[revenue]' role='measure' type='quantitative' />
